<script>
    var etapas = ["Lavar", "Passar", "dobrar", "Guardar"];
    //1 a unicialização Deve comecar com o ultimo indice do array
    //2 a condicao tem que verificar se e maior ou igual a zero
    //3 a iteracao tem que ser decrementada
    for (var i = etapas.length - 1; i >= 0; i--) {
        alert("Etapa " + (i + 1) + ": " + etapas[i]);
    }
</script>